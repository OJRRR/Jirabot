# Jira 配置
JIRA_SERVER=https://your-jira-instance.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your-api-token

# LLM 模型配置（OpenAI 兼容接口）
MODEL_API_BASE=https://api.openai.com/v1
MODEL_API_KEY=sk-your-api-key
MODEL_NAME=gpt-4

# Agent 配置
AGENT_VERBOSE=False
AGENT_MAX_ITERATIONS=3
AI_TEMPERATURE=0.5

# 目标项目（逗号分隔，留空或设为 ALL 表示所有项目）
# PROJECTS=PROJ1, PROJ2, PROJ3

# 自定义字段 ID（如不设置，首次启动时会自动探测）
# TARGET_START_FIELD=customfield_16519
# TARGET_END_FIELD=customfield_16520
# EPIC_LINK_FIELD_ID=customfield_10001

# 查询限制
# MAX_TASKS_PER_TOOL=50          # 单次工具调用最大返回条数
# JQL_PAGE_SIZE=100              # JQL 分页每页大小
# ISSUE_FETCH_LIMIT=5000         # 报告生成时最多拉取 issue 数（防止全量拖垮）

# 风险评分配置
# RISK_PROGRESS_LOW=30           # 低于此值判定严重滞后
# RISK_PROGRESS_MED=50           # 低于此值判定滞后
# RISK_PROGRESS_HIGH=70          # 低于此值判定偏慢
# RISK_OVERDUE_HIGH=5            # 超期任务≥此值→较多
# RISK_OVERDUE_LOW=1             # 超期任务≥此值→存在
# RISK_HIGH_PRIORITY_HIGH=10     # 高优积压≥此值→严重
# RISK_HIGH_PRIORITY_LOW=5       # 高优积压≥此值→存在
# RISK_BLOCKED_HIGH=3            # 阻塞任务≥此值→较多
# RISK_BLOCKED_LOW=1             # 阻塞任务≥此值→存在
# RISK_SCORE_HIGH=60             # ≥此值→高风险
# RISK_SCORE_MED=30              # ≥此值→中风险

# 报告清理
# REPORT_MAX_AGE_DAYS=30         # 报告保留天数
# REPORTS_DIR=./reports          # 报告输出目录

# 上传目录（Excel 导入等）
# UPLOAD_DIR=./uploads

# 并发配置
# REPORT_PARALLEL_WORKERS=5      # 项目集报告并行查询的最大线程数
