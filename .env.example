# Jira 配置
JIRA_SERVER=https://your-jira-instance.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your-api-token

# LLM 模型配置（OpenAI 兼容接口）
MODEL_API_BASE=https://api.openai.com/v1
MODEL_API_KEY=sk-your-api-key
MODEL_NAME=gpt-4

# Agent 配置
AGENT_VERBOSE=False
AGENT_MAX_ITERATIONS=3
AI_TEMPERATURE=0.5

# 目标项目（逗号分隔，留空或设为 ALL 表示所有项目）
# PROJECTS=PROJ1, PROJ2, PROJ3

# 自定义字段 ID（如不设置，首次启动时会自动探测）
# TARGET_START_FIELD=customfield_12914
# TARGET_END_FIELD=customfield_12915
# EPIC_LINK_FIELD_ID=customfield_10001

# 查询限制
# MAX_TASKS_PER_TOOL=50
# JQL_PAGE_SIZE=100

# 风险评分配置
# RISK_PROGRESS_LOW=30
# RISK_PROGRESS_MED=50
# RISK_PROGRESS_HIGH=70
# RISK_OVERDUE_HIGH=5
# RISK_OVERDUE_LOW=1

# 报告清理
# REPORT_MAX_AGE_DAYS=30
# REPORTS_DIR=./reports
