# ── Jira 连接 ──
JIRA_SERVER=https://your-jira-instance.com
JIRA_USER=your-username
JIRA_TOKEN=your-api-token

# ── LLM 模型（OpenAI 兼容 API）──
MODEL_API_BASE=https://api.openai.com/v1
MODEL_API_KEY=your-api-key
MODEL_NAME=gpt-4o
AI_TEMPERATURE=0.5

# ── 目标项目（逗号分隔，ALL=所有项目）──
PROJECTS=KO,RDE

# ── Jira 自定义字段（可选，留空则自动探测）──
TARGET_START_FIELD=customfield_16519
TARGET_END_FIELD=customfield_16520
EPIC_NAME_FIELD_ID=
EPIC_LINK_FIELD_ID=

# ── 查询配置 ──
MAX_TASKS_PER_TOOL=50
JQL_PAGE_SIZE=100
ISSUE_FETCH_LIMIT=5000
REPORT_PARALLEL_WORKERS=5

# ── 风险评分阈值 ──
RISK_PROGRESS_LOW=30
RISK_PROGRESS_MED=50
RISK_PROGRESS_HIGH=70
RISK_OVERDUE_HIGH=5
RISK_OVERDUE_LOW=1
RISK_HIGH_PRIORITY_HIGH=10
RISK_HIGH_PRIORITY_LOW=5
RISK_BLOCKED_HIGH=3
RISK_BLOCKED_LOW=1
RISK_SCORE_HIGH=60
RISK_SCORE_MED=30

# ── 报告 ──
REPORT_MAX_AGE_DAYS=30

# ── Web 服务 ──
WEB_PORT=5000
WEB_HOST=127.0.0.1
WEB_THREADS=4
WEB_CLEANUP_ON_START=1

# ── 流式响应 ──
WEB_STREAM_TIMEOUT=120
WEB_STREAM_WORKERS=4

# ── 开发模式（true=Flask dev server, 默认=waitress 生产模式）──
# DEBUG=true

# ── 日志 ──
LOG_LEVEL=INFO

# ── 会话存储（memory/sqlite/async，默认 memory）──
JIRA_SESSION_BACKEND=memory

# ── WBS 子 Agent 独立模型（可选，不设置则使用主模型）──
# WBS_MODEL_NAME=gpt-4o-mini
# WBS_MODEL_API_KEY=your-api-key
# WBS_MODEL_API_BASE=https://api.openai.com/v1

# ── 其他 ──
AUTO_DETECT_FIELDS=1
JIRA_MIN_INTERVAL=0.1
